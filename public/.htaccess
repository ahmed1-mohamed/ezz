# Enable Cache-Control for efficient browser caching (Lighthouse 100/100)
<IfModule mod_headers.c>
  # 1 Year Cache for Static Web Assets & Images (WebP, JS, CSS, Fonts, SVG)
  <FilesMatch "\.(js|css|webp|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML pages should revalidate for instant updates
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# Enable Gzip and Brotli compression to improve image & bundle delivery
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml image/webp
</IfModule>
